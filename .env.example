# AgentX Hackathon — SRE Incident Triage Agent (v2 Hexagonal)
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Only the LLM keys for your chosen primary/fallback are strictly required.
# Every other adapter has a working default (mock/postgres/faiss).

# ============================================================
# LLM — primary + fallback (circuit breaker)
# ============================================================
LLM_PROVIDER=gemini                # gemini | openrouter | anthropic | openai
LLM_FALLBACK_PROVIDER=openrouter   # same set, or 'none' to disable fallback
LLM_CIRCUIT_BREAKER_THRESHOLD=3
LLM_CIRCUIT_BREAKER_COOLDOWN_S=60
LLM_TIMEOUT_S=25

# Gemini (default primary — multimodal)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (default fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ============================================================
# Ticket provider
# ============================================================
TICKET_PROVIDER=mock               # mock | gitlab | jira

# GitLab (only if TICKET_PROVIDER=gitlab)
GITLAB_BASE_URL=
GITLAB_TOKEN=
GITLAB_PROJECT_ID=

# Jira (only if TICKET_PROVIDER=jira)
JIRA_BASE_URL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=

# ============================================================
# Notification provider
# ============================================================
NOTIFY_PROVIDER=mock               # mock | slack | email | teams

SLACK_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================
# Storage
# ============================================================
STORAGE_PROVIDER=postgres          # memory | postgres
APP_DATABASE_URL=postgresql+asyncpg://sre:sre@app-db:5432/sre_agent

# ============================================================
# Context / RAG
# ============================================================
CONTEXT_PROVIDER=faiss             # static | faiss
FAISS_INDEX_PATH=/data/faiss/eshop.index

# ============================================================
# Mock services (set automatically by docker-compose)
# ============================================================
MOCK_SERVICES_URL=http://mock-services:9000

# ============================================================
# Observability — Langfuse (self-hosted via docker-compose)
# ============================================================
# Dashboard: http://localhost:3000  (after `docker compose up`)
# Default credentials work out-of-the-box; change before any non-local deploy.
#
# Set LANGFUSE_ENABLED=false to disable tracing entirely (e.g. CI unit tests).
LANGFUSE_ENABLED=true

# Public/secret key pair — must match the values in the Langfuse DB.
# The docker-compose seed creates exactly these keys automatically.
LANGFUSE_PUBLIC_KEY=pk-lf-demo
LANGFUSE_SECRET_KEY=sk-lf-demo

# Internal Docker network hostname used by the sre-agent container.
# Change to http://localhost:3000 only when running sre-agent outside Docker.
LANGFUSE_HOST=http://langfuse-web:3000

# Langfuse service-level secrets (used by the langfuse-web container).
# Generate with: openssl rand -hex 32
# Generate with: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=REPLACE_WITH_openssl_rand_hex_32
LANGFUSE_SALT=REPLACE_WITH_openssl_rand_hex_32

# ============================================================
# Application
# ============================================================
LOG_LEVEL=INFO
APP_ENV=development
MAX_UPLOAD_SIZE_MB=5
GUARDRAILS_LLM_JUDGE_ENABLED=true

# API authentication (SEC-CR-001)
# All incident, webhook, and feedback endpoints require this header:
#   X-API-Key: <value>
# Health (/health), metrics (/metrics), and UI routes are exempt.
# Change this value for any non-local deployment.
SRE_API_KEY=sre-demo-key
