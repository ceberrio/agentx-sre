# AgentX Hackathon — SRE Incident Triage Agent (v2 Hexagonal)
# Copy this file to .env — it works out of the box for local demo use.
#   cp .env.example .env
#
# All required fields already have working demo defaults.
# For production deployments, replace CONFIG_ENCRYPTION_KEY, LANGFUSE_NEXTAUTH_SECRET,
# and LANGFUSE_SALT with securely generated values.

# ============================================================
# LLM configuration (provider, model, API keys, circuit breaker params)
# is managed in the database via the llm_config table (ARC-023).
# Configure via the UI at http://localhost:5173 → LLM Config.
# Do NOT add LLM_PROVIDER, LLM_MODEL, or LLM_*KEY variables here.
#
# SEED-TIME ONLY — read once by "alembic upgrade head" on a fresh DB.
# Not read by the application at runtime.
# Leave empty to boot in stub mode; configure the key from the UI afterwards.
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ============================================================
# Ticket provider
# ============================================================
TICKET_PROVIDER=mock               # mock | gitlab | jira

# GitLab (only if TICKET_PROVIDER=gitlab)
GITLAB_BASE_URL=
GITLAB_TOKEN=
GITLAB_PROJECT_ID=

# Jira (only if TICKET_PROVIDER=jira)
JIRA_BASE_URL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=

# ============================================================
# Notification provider
# ============================================================
NOTIFY_PROVIDER=mock               # mock | slack | email | teams

SLACK_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================
# Storage
# ============================================================
STORAGE_PROVIDER=postgres          # memory | postgres
APP_DATABASE_URL=postgresql+asyncpg://sre:sre@app-db:5432/sre_agent

# ============================================================
# Context / RAG
# ============================================================
CONTEXT_PROVIDER=faiss             # static | faiss
FAISS_INDEX_PATH=/data/faiss/eshop.index

# ============================================================
# Mock services (set automatically by docker-compose)
# ============================================================
MOCK_SERVICES_URL=http://mock-services:9000

# ============================================================
# Observability — Langfuse (self-hosted via docker-compose)
# ============================================================
# Dashboard: http://localhost:3000  (after `docker compose up`)
# Default credentials work out-of-the-box; change before any non-local deploy.
#
# Set LANGFUSE_ENABLED=false to disable tracing entirely (e.g. CI unit tests).
LANGFUSE_ENABLED=true

# Public/secret key pair — must match the values in the Langfuse DB.
# The docker-compose seed creates exactly these keys automatically.
LANGFUSE_PUBLIC_KEY=pk-lf-demo
LANGFUSE_SECRET_KEY=sk-lf-demo

# Internal Docker network hostname used by the sre-agent container.
# Change to http://localhost:3000 only when running sre-agent outside Docker.
LANGFUSE_HOST=http://langfuse-web:3000

# Langfuse service-level secrets (used by the langfuse-web container).
# Generate with: openssl rand -hex 32
# ⚠ DEMO VALUES — work out of the box for local development.
# Generate new secure values before any real (non-demo) deployment.
LANGFUSE_NEXTAUTH_SECRET=<generate: openssl rand -hex 32>
LANGFUSE_SALT=<generate: openssl rand -hex 32>

# ============================================================
# Application
# ============================================================
LOG_LEVEL=INFO
APP_ENV=development
MAX_UPLOAD_SIZE_MB=5
GUARDRAILS_LLM_JUDGE_ENABLED=true

# ============================================================
# Authentication (HU-P017, HU-P018)
# ============================================================

# JWT secret — CHANGE THIS in any non-local deployment.
# Protected endpoints accept Bearer JWT (primary) or X-API-Key (backward compat).
# The React UI handles JWT automatically after login via POST /auth/mock-google-login.
# API clients and CI scripts can still use X-API-Key during the migration period.
#
# Generate a secure value: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=sre-dev-jwt-secret-change-in-production

# JWT expiry in minutes (default 8 hours)
JWT_EXPIRE_MINUTES=480

# Algorithm (do not change unless you know what you are doing)
JWT_ALGORITHM=HS256

# Legacy API key (SEC-CR-001) — backward compat for CI/scripts.
# Endpoints protected by dual-auth accept EITHER Bearer JWT OR X-API-Key.
# Health (/health), metrics (/metrics), /auth/mock-google-login, and
# /context/status are fully public (no auth required).
# Change this value for any non-local deployment.
SRE_API_KEY=sre-demo-key

# ============================================================
# Encryption key for credentials stored in DB (HU-P029, HU-P032)
# ============================================================
# Required when LLM_CONFIG_PROVIDER=postgres or PLATFORM_CONFIG_PROVIDER=postgres.
# Generate a new key before running (choose one method):
#   Docker: docker run --rm python:3.11-slim sh -c "pip install cryptography -q && python -c \"from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())\""
#   Local:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER reuse this value across environments. NEVER commit the real value.
CONFIG_ENCRYPTION_KEY=
